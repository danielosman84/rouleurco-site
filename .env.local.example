# RouleurCo GoHighLevel (LeadConnector) integration — names only, no secrets.
# Copy to .env.local (git-ignored) and fill in real values. Set the same vars in
# Vercel project settings for production.

# RouleurCo Private Integration Token.
# SECRET — server-only. Never prefix NEXT_PUBLIC_, never log, never commit.
# Generate in RouleurCo -> Settings -> Private Integrations with read/write
# scopes for contacts, opportunities and pipelines.
GHL_PIT=

# RouleurCo sub-account location id. (NOT the UVH account kRfviw1Gs30Ek0UF2fYE.)
GHL_LOCATION_ID=hCW1XgNUW2gssImbG9EN

# Target pipeline + entry stage for website soft-interest opportunities.
# Leave blank until the live RouleurCo pipelines are fetched and the target is
# confirmed. While blank, the contact is still captured and the opportunity step
# is skipped (no guessing, no UVH IDs).
GHL_PIPELINE_ID=
GHL_PIPELINE_STAGE_ID=

# NOTE: the old inbound-webhook variable NEXT_PUBLIC_GHL_WEBHOOK_URL is removed —
# the form now posts to the same-origin /api/register-interest route instead.
